# Knowledge Base Service Configuration

# Authentication
API_KEY=your-secret-api-key-here

# Database
DATABASE_URL=sqlite:///./data/kb_service.db

# Vector Storage (optional)
VECTOR_STORE_ENABLED=true
VECTOR_STORE_TYPE=chromadb

# ChromaDB Configuration (Local)
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=knowledge_base

# ChromaDB Cloud Configuration (optional - for Chroma Cloud)
# CHROMA_AUTH_TOKEN=your-chroma-cloud-auth-token
# CHROMA_API_KEY=your-chroma-cloud-api-key
# CHROMA_TENANT=your-tenant
# CHROMA_DATABASE=your-database

# Embedding Configuration
EMBEDDING_ENABLED=true
DEFAULT_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
ALTERNATIVE_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
MAX_TOKENS_THRESHOLD=7000

# Chunking Configuration
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=200

# File Upload Configuration
MAX_FILE_SIZE=50MB
UPLOAD_DIR=./data/uploads

# Document Processing - Docling is primary parser
USE_DOCLING_PARSING=true

# OCR Configuration (disabled by default for minimal setup)
OCR_ENABLED=false

# Development
DEBUG=false
LOG_LEVEL=INFO

# === MINIMAL SETUP (no ML/AI dependencies) ===
# For a minimal setup without embeddings and vector search:
# VECTOR_STORE_ENABLED=false
# EMBEDDING_ENABLED=false
# OCR_ENABLED=false
# 
# Then use requirements-minimal.txt instead of requirements.txt